<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <changeSet id="0008-add-column-nickname-userProfile" author="thang-anonymous">
    <preConditions onFail="MARK_RAN">
      <tableExists tableName="user_profile"/>
    </preConditions>
    <addColumn tableName="user_profile">
      <column name="nick_name" type="varchar(255)" >
        <constraints unique="true"
          uniqueConstraintName="uq_user_profile_nickname"
        />
      </column>
    </addColumn>
  </changeSet>
</databaseChangeLog>