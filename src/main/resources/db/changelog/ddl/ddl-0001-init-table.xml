<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
    http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd">

  <changeSet id="20260320-001" author="thang-anonymous">
    <preConditions onFail="MARK_RAN">
      <not>
        <tableExists tableName="user"/>
      </not>
    </preConditions>
    <createTable tableName="user">
      <column name="id" type="BIGINT" autoIncrement="true">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="username" type="VARCHAR(50)">
        <constraints nullable="false" unique="true"/>
      </column>
      <column name="email" type="VARCHAR(150)">
        <constraints nullable="false" unique="true"/>
      </column>
      <column name="password" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>
      <column name="full_name" type="VARCHAR(100)"/>
      <column name="phone_number" type="VARCHAR(20)"/>
      <column name="status" type="VARCHAR(20)" defaultValue="PENDING_ACTIVE">
        <constraints nullable="false"/>
      </column>
      <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
      <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
    </createTable>
  </changeSet>
  <changeSet id="20260320-002" author="thang-anonymous">
    <preConditions onFail="MARK_RAN">
      <not>
        <tableExists tableName="role"/>
      </not>
    </preConditions>
    <createTable tableName="role">
      <column name="id" type="BIGINT" autoIncrement="true">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="role_name" type="VARCHAR(50)">
        <constraints nullable="false" unique="true"/>
      </column>
      <column name="description" type="VARCHAR(255)"/>
    </createTable>
  </changeSet>
  <changeSet id="20260320-003" author="thang-anonymous">
    <preConditions onFail="MARK_RAN">
      <not>
        <tableExists tableName="user_role"/>
      </not>
    </preConditions>
    <createTable tableName="user_role">
      <column name="id" type="BIGINT" autoIncrement="true">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="user_id" type="BIGINT">
        <constraints nullable="false" foreignKeyName="fk_user_role_user" referencedTableName="user" referencedColumnNames="id"/>
      </column>
      <column name="role_id" type="BIGINT">
        <constraints nullable="false" foreignKeyName="fk_user_role_role" referencedTableName="role" referencedColumnNames="id"/>
      </column>
      <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
      <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP" />
    </createTable>
  </changeSet>
  <changeSet id="20260320-004" author="thang-anonymous">
    <preConditions onFail="MARK_RAN">
      <not>
        <tableExists tableName="user_profile"/>
      </not>
    </preConditions>
    <createTable tableName="user_profile">
      <column name="id" type="BIGINT" autoIncrement="true">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="user_id" type="BIGINT">
        <constraints nullable="false" unique="true" foreignKeyName="fk_profile_user" referencedTableName="user" referencedColumnNames="id"/>
      </column>
      <column name="birthdate" type="DATE"/>
      <column name="gender" type="VARCHAR(10)"/>
      <column name="address" type="VARCHAR(255)"/>
      <column name="bio" type="TEXT"/>
      <column name="avatar" type="VARCHAR(255)"/>
      <column name="company" type="VARCHAR(100)"/>
      <column name="year_experience" type="BIGINT" defaultValueNumeric="0"/>
      <column name="education_level" type="VARCHAR(100)"/>
      <column name="facebook" type="VARCHAR(255)"/>
      <column name="personal_website" type="VARCHAR(255)"/>
      <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
      <column name="updated_at" type="TIMESTAMP"  defaultValueComputed="CURRENT_TIMESTAMP"/>
    </createTable>
  </changeSet>
  <changeSet id="20260320-005" author="thang-anonymous">
    <preConditions onFail="MARK_RAN">
      <not>
        <tableExists tableName="category"/>
      </not>
    </preConditions>
    <createTable tableName="category">
      <column name="id" type="BIGINT" autoIncrement="true">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="name" type="VARCHAR(100)">
        <constraints nullable="false"/>
      </column>
      <column name="description" type="TEXT"/>
      <column name="slug" type="VARCHAR(150)">
        <constraints  unique="true"/>
      </column>
      <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
      <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP" />
    </createTable>
  </changeSet>
  <changeSet id="20260320-006" author="thang-anonymous">
    <preConditions onFail="MARK_RAN">
      <not>
        <tableExists tableName="content"/>
      </not>
    </preConditions>
    <createTable tableName="content">
      <column name="id" type="BIGINT" autoIncrement="true">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="category_id" type="BIGINT">
        <constraints nullable="false" foreignKeyName="fk_content_category" referencedTableName="category" referencedColumnNames="id"/>
      </column>
      <column name="creator_id" type="BIGINT">
        <constraints nullable="false" foreignKeyName="fk_content_user" referencedTableName="user" referencedColumnNames="id"/>
      </column>
      <column name="title" type="VARCHAR(255)" />
      <column name="description" type="TEXT"/>
      <column name="status" type="VARCHAR(20)" defaultValue="DRAFT"/>
      <column name="level" type="VARCHAR(20)"/>
      <column name="price" type="DECIMAL(19,2)" defaultValueNumeric="0.00"/>
      <column name="view_count" type="BIGINT" defaultValueNumeric="0"/>
      <column name="purchase_count" type="BIGINT" defaultValueNumeric="0"/>
      <column name="published_at" type="TIMESTAMP"/>
      <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
      <column name="updated_at" type="TIMESTAMP"  defaultValueComputed="CURRENT_TIMESTAMP"/>
    </createTable>
  </changeSet>
  <changeSet id="20260320-007" author="thang-anonymous">
    <preConditions onFail="MARK_RAN">
      <not>
        <tableExists tableName="block"/>
      </not>
    </preConditions>
    <createTable tableName="block">
      <column name="id" type="BIGINT" autoIncrement="true">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="content_id" type="BIGINT">
        <constraints nullable="false" foreignKeyName="fk_block_content" referencedTableName="content" referencedColumnNames="id"/>
      </column>
      <column name="parent_block_id" type="BIGINT">
        <constraints foreignKeyName="fk_block_parent" referencedTableName="block" referencedColumnNames="id"/>
      </column>
      <column name="type" type="VARCHAR(50)"/>
      <column name="text_content" type="TEXT"/>
      <column name="properties" type="JSON"/>
      <column name="position" type="BIGINT" defaultValueNumeric="0"/>
      <column name="is_free" type="BOOLEAN" defaultValueBoolean="false"/>
      <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
      <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP" />
    </createTable>
  </changeSet>
  <changeSet id="20260320-008" author="thang-anonymous">
    <preConditions onFail="MARK_RAN">
      <not>
        <tableExists tableName="content_review"/>
      </not>
    </preConditions>
    <createTable tableName="content_review">
      <column name="id" type="BIGINT" autoIncrement="true">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="content_id" type="BIGINT">
        <constraints nullable="false" foreignKeyName="fk_review_content_main" referencedTableName="content" referencedColumnNames="id"/>
      </column>
      <column name="moderator_id" type="BIGINT">
        <constraints nullable="false" foreignKeyName="fk_review_moderator" referencedTableName="user" referencedColumnNames="id"/>
      </column>
      <column name="action" type="VARCHAR(50)"/>
      <column name="feedback" type="TEXT"/>
      <column name="action_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
    </createTable>
  </changeSet>

  <changeSet id="20260320-009" author="thang-anonymous">
    <preConditions onFail="MARK_RAN">
      <not>
        <tableExists tableName="user_verification"/>
      </not>
    </preConditions>
    <createTable tableName="user_verification">
      <column name="id" type="BIGINT" autoIncrement="true">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="user_id" type="BIGINT">
        <constraints nullable="true" foreignKeyName="fk_user_verification_user" referencedTableName="user" referencedColumnNames="id"/>
      </column>
      <column name="verification_code" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>
      <column name="expired_at" type="TIMESTAMP">
        <constraints nullable="false"/>
      </column>
      <column name="channel" type="VARCHAR(50)">
        <constraints nullable="false"/>
      </column>
      <column name="verified_at" type="TIMESTAMP"/>
      <column name="receiver" type="VARCHAR(255)">
        <constraints nullable="false"/>
      </column>
      <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
    </createTable>
  </changeSet>

  <changeSet id="20260313-004" author="thang-anonymous">
    <preConditions onFail="MARK_RAN" >
      <not>
        <tableExists tableName="support_ticket"/>
      </not>
    </preConditions>
    <createTable tableName="support_ticket">
      <column name="id" type="bigint" autoIncrement="true">
        <constraints primaryKey="true"/>
      </column>
      <column name="userId" type="bigint">
        <constraints foreignKeyName="fk_support_ticket_userid" referencedTableName="user" referencedColumnNames="id"/>
      </column>
      <column name="issue" type="TEXT">
        <constraints nullable="false"/>
      </column>
      <column name="status" type="varchar(50)" defaultValue="Received"/>
      <column name="create_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"/>
    </createTable>
  </changeSet>

  <changeSet id="20260320-010" author="thang-anonymous">
    <preConditions onFail="MARK_RAN">
      <not>
        <tableExists tableName="ticket_message"/>
      </not>
    </preConditions>
    <createTable tableName="ticket_message">
      <column name="id" type="bigint" autoIncrement="true">
        <constraints primaryKey="true"/>
      </column>
      <column name="userId" type="bigint">
        <constraints foreignKeyName="fk_support_ticket_message_userid" referencedTableName="user" referencedColumnNames="id"/>
      </column>
      <column name="message" type="TEXT">
        <constraints nullable="false"/>
      </column>
      <column name="support_ticket" type="bigint">
        <constraints foreignKeyName="fk_support_ticket_message" referencedTableName="support_ticket" referencedColumnNames="id"/>
      </column>
      <column name="create_at" type="timestamp" defaultValueComputed="CURRENT_TIMESTAMP"/>
    </createTable>
  </changeSet>
  <changeSet id="20260320-011" author="thang-anonymous">
    <preConditions onFail="MARK_RAN">
      <not>
        <tableExists tableName="transaction"/>
      </not>
    </preConditions>
    <createTable tableName="transaction">
      <column name="id" type="BIGINT" autoIncrement="true">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="user_id" type="BIGINT">
        <constraints nullable="false" foreignKeyName="fk_transaction_user" referencedTableName="user" referencedColumnNames="id"/>
      </column>
      <column name="type" type="VARCHAR(50)">
        <constraints nullable="false"/>
      </column>
      <column name="amount" type="DECIMAL(19,2)">
        <constraints nullable="false"/>
      </column>
      <column name="balance_before" type="DECIMAL(19,2)">
        <constraints nullable="false"/>
      </column>
      <column name="balance_after" type="DECIMAL(19,2)">
        <constraints nullable="false"/>
      </column>
      <column name="description" type="TEXT"/>
      <column name="reference_id" type="VARCHAR(255)"/>
      <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
    </createTable>
  </changeSet>
  <changeSet id="20260320-012" author="thang-anonymous">
    <preConditions onFail="MARK_RAN">
      <not>
        <tableExists tableName="user_skill"/>
      </not>
    </preConditions>
    <createTable tableName="user_skill">
      <column name="id" type="BIGINT" autoIncrement="true">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="profile_id" type="BIGINT">
        <constraints nullable="false" foreignKeyName="fk_user_skill_profile" referencedTableName="user_profile" referencedColumnNames="id"/>
      </column>
      <column name="skill_name" type="VARCHAR(100)">
        <constraints nullable="false"/>
      </column>
      <column name="proficiency_level" type="INTEGER"/>
      <column name="years_of_experience" type="INTEGER"/>
      <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
      <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
      <column name="created_by" type="BIGINT"/>
      <column name="updated_by" type="BIGINT"/>
    </createTable>
  </changeSet>
  <changeSet id="20260320-013" author="thang-anonymous">
    <preConditions onFail="MARK_RAN">
      <not>
        <tableExists tableName="wallet"/>
      </not>
    </preConditions>
    <createTable tableName="wallet">
      <column name="id" type="BIGINT" autoIncrement="true">
        <constraints primaryKey="true" nullable="false"/>
      </column>
      <column name="user_id" type="BIGINT">
        <constraints nullable="false" unique="true" foreignKeyName="fk_wallet_user" referencedTableName="user" referencedColumnNames="id"/>
      </column>
      <column name="balance" type="DECIMAL(19,2)" defaultValueNumeric="0.00">
        <constraints nullable="false"/>
      </column>
      <column name="version" type="BIGINT" defaultValueNumeric="0"/>
      <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
      <column name="updated_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
    </createTable>
  </changeSet>
  <changeSet id="20260320-014" author="thang-anonymous">
